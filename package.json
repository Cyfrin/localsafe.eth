{
  "name": "localsafe.eth",
  "version": "0.3.1",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs}\"",
    "localsafe": "next build && npx serve out -p 3000",
    "snap:build": "pnpm --filter localsafe-snap build",
    "snap:watch": "pnpm --filter localsafe-snap start",
    "snap:serve": "pnpm --filter localsafe-snap serve",
    "anvil": "anvil --load-state ./anvil-safe-state.json --block-time 1 --chain-id 31337 --port 8545",
    "anvil:two": "anvil --load-state ./anvil-safe-state.json --block-time 1 --chain-id 31338 --port 8546",
    "test:e2e": "bash tests/scripts/start-anvil-and-test.sh",
    "test:e2e:ui": "bash tests/scripts/start-anvil-and-test.sh --ui",
    "test:clean": "pkill -9 ^next-server || true; pkill -9 ^anvil",
    "postinstall": "git config core.hooksPath .githooks && echo 'Git hooks installed' || true"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "2.2.11",
    "@reown/walletkit": "1.5.5",
    "@tanstack/react-query": "5.101.0",
    "@wagmi/core": "2.22.1",
    "@walletconnect/core": "2.23.9",
    "@walletconnect/types": "2.23.9",
    "ethers": "6.16.0",
    "next": "15.5.19",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.0",
    "viem": "2.52.2",
    "wagmi": "2.19.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "20.19.11",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@wonderland/walletless": "1.2.0",
    "daisyui": "5.5.23",
    "eslint": "9.34.0",
    "eslint-config-next": "15.5.19",
    "eslint-config-prettier": "10.1.8",
    "playwright-core": "1.60.0",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.2"
  }
}
